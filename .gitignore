# ─────────────────────────────────────────
#  Mentor 11 — .gitignore
# ─────────────────────────────────────────

# ── Entorno virtual Python ────────────────
venv/
.venv/
env/

# ── Variables de entorno ──────────────────
.env
.env.local
.env.production

# ── Python ────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Pytest / cobertura ────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Alembic ───────────────────────────────
# Las migraciones SÍ se suben (no ignorar versions/)
# Solo ignorar archivos temporales que Alembic pueda generar
*.pyc

# ── IDEs ──────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Sistema operativo ─────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Frontend (Node / React) ───────────────
node_modules/
dist/
build/
.next/
frontend/.env
frontend/.env.local

# ── Logs ──────────────────────────────────
*.log
logs/

# ── Archivos temporales ───────────────────
*.tmp
*.swp
*.bak

