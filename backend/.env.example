# ─────────────────────────────────────────
#  Mentor 11 – Variables de entorno
#  Copiar este archivo como .env y completar
# ─────────────────────────────────────────

# Base de datos PostgreSQL
# Puerto 5432 es el predeterminado de PostgreSQL.
# Si tu instalación usa otro puerto (ej: 5433), cámbialo aquí.
# IMPORTANTE: ambas URLs deben usar la misma contraseña.
DATABASE_URL=postgresql+asyncpg://postgres:TU_PASSWORD@localhost:5432/mentor
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:TU_PASSWORD@localhost:5432/mentor

# JWT
SECRET_KEY=cambia_esta_clave_por_una_muy_segura_de_al_menos_32_caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Entorno
# development | production  (sin comentarios en la misma línea)
ENVIRONMENT=development
DEBUG=true

# CORS — formato JSON array obligatorio para pydantic-settings v2
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Email (para recuperación de contraseña)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_app_password
EMAIL_FROM=noreply@mentor11.com

# IA (para retroalimentación Premium)
OPENAI_API_KEY=sk-...
